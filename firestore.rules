// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Salons ────────────────────────────────────────────────────────────────
    // Anyone can read salons (for discovery)
    // Only authenticated salon staff can write
    match /salons/{salonId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Queue subcollection
      match /queue/{entryId} {
        // Any logged-in user can read & join the queue
        allow read:   if true;
        allow create: if request.auth != null || true; // allow guest check-ins too
        // Updates only by auth users (salon staff or entry owner)
        allow update: if request.auth != null ||
                         resource.data.customerId == request.auth.uid;
        allow delete: if request.auth != null;
      }
    }

    // ── Customers ─────────────────────────────────────────────────────────────
    // Users can only read/write their own profile and visit history
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /visits/{visitId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null; // written by server/functions
      }
    }
  }
}
